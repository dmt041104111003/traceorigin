{
  "name": "iot5-qr-code-traceability",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "get-product": "tsx ./cli/get-product.ts",
    "dev": "next dev --turbopack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mint": "tsx ./cli/mint.ts",
    "update": "tsx ./cli/update.ts",
    "contract:fmt": "cd ./contract && aiken fmt",
    "contract:test": "cd ./contract && aiken check",
    "contract:build": "cd ./contract && aiken build",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const src=path.resolve('node_modules/libsodium-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs');const dest=path.resolve('node_modules/libsodium-wrappers-sumo/dist/modules-sumo-esm/libsodium-sumo.mjs');if(fs.existsSync(src)&&!fs.existsSync(dest)){fs.mkdirSync(path.dirname(dest),{recursive:true});fs.copyFileSync(src,dest);}\""
  },
  "dependencies": {
    "@blockfrost/blockfrost-js": "^6.1.0",
    "@meshsdk/core": "1.8.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.20",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "axios": "^1.13.4",
    "cbor": "^10.0.11",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "libsodium-sumo": "^0.7.13",
    "libsodium-wrappers-sumo": "^0.7.13",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "vercel": "^50.25.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "copy-webpack-plugin": "^13.0.1",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
